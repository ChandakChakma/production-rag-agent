# ── LLM Provider ─────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Vector Store ─────────────────────────────────────────────────────
VECTOR_STORE_TYPE=chroma           # chroma | pinecone
CHROMA_PERSIST_DIR=./data/chroma_db
# PINECONE_API_KEY=...
# PINECONE_INDEX_NAME=prod-rag

# ── Retrieval ────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=50
RERANK_TOP_K=5
HYBRID_ALPHA=0.5                   # 0=pure BM25, 1=pure dense

# ── Agent ────────────────────────────────────────────────────────────
AGENT_MAX_ITERATIONS=8
AGENT_TEMPERATURE=0.0
MEMORY_MAX_TOKENS=2000

# ── API ──────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_KEY=dev-secret-key-change-in-prod

# ── Observability ────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json                    # json | console
OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_PORT=8001
ENABLE_TRACING=true

# ── Caching ──────────────────────────────────────────────────────────
CACHE_DIR=./data/cache
EMBEDDING_CACHE_SIZE_GB=1
SEMANTIC_CACHE_THRESHOLD=0.95      # cosine similarity threshold

# ── Evaluation ───────────────────────────────────────────────────────
EVAL_LLM_MODEL=gpt-4o
EVAL_BATCH_SIZE=5
